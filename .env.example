# FoodGenius Content Factory — переменные окружения (значения НЕ коммитим, см. .env)

# n8n
N8N_URL=
N8N_API_KEY=

# Gemini (Google AI Studio, paid tier — текст/Veo/Nano Banana)
GEMINI_API_KEY=
GEMINI_PROJECT=

# YouTube Data API v3 (тренды + контент-конкуренты)
YOUTUBE_API_KEY=

# Telegram (ревью-доставка роликов)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Сервер Timeweb (ffmpeg-рендер через SSH-ноду n8n)
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASSWORD=

# Ресёрч
PERPLEXITY_API_KEY=
APIFY_TOKEN=
SCRAPECREATORS_API_KEY=

# Notion (редплан)
NOTION_TOKEN=
NOTION_PARENT=
NOTION_DB_IDEAS=
NOTION_DB_POSTS=
NOTION_DB_PUBLISHED=
NOTION_DB_ANALYTICS=
NOTION_DB_COMPETITOR_SIGNALS=

# Анти-зацикливание / лимиты
MAX_ITEMS_PER_RUN=5
MIN_TOPIC_REPEAT_DAYS=30

# GitHub (бэкап)
GITHUB_USER=
GITHUB_TOKEN=

# Публикация (Phase 2a/2b)
UPLOAD_POST_API_KEY=
