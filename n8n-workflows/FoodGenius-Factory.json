      "parameters": {
        "jsCode": "const res=($input.first().json.results)||[];\nif(!res.length){ return []; }\nconst p=res[0]; const pr=p.properties;\nconst g=(n,t)=>{const x=pr[n]||{}; if(t=='title')return (x.title||[]).map(z=>z.plain_text).join(''); if(t=='rt')return (x.rich_text||[]).map(z=>z.plain_text).join(''); return '';};\nlet concept={}; try{ concept=JSON.parse(g('final_text','rt')); }catch(e){}\nconst scenes=concept.scenes||[];\nconst veo=(scenes[0]&&scenes[0].veo_prompt)||(g('title','title')+', vertical 9:16, cinematic');\nconst title=g('title','title').slice(0,95);\nconst sc=g('start_code','rt');\nconst desc=(concept.caption||title)+'\\n\\n'+(concept.cta||'')+'\\nhttps://t.me/foodgenius_ai_bot?start=ref_'+sc+'\\n\\n'+((concept.hashtags||[]).join(' '))+' #shorts';\nreturn [{ json: { page_id:p.id, title, veo:veo, description:desc, start_code:sc } }];"
