      "parameters": {
        "jsCode": "const idea=$('Parse idea').first().json;\nconst raw=$input.first().json.candidates[0].content.parts[0].text;\nconst concept=JSON.parse(raw.trim().replace(/^```json/i,'').replace(/^```/,'').replace(/```$/,'').trim());\nconst rt=v=>({rich_text:[{text:{content:String(v==null?'':v).slice(0,1900)}}]});\nconst link='https://t.me/foodgenius_ai_bot?start=ref_'+idea.start_code;\nconst caption=(concept.caption||idea.topic)+'\\n\\n'+(concept.cta||'')+' '+link;\nconst props={\n  'title':{title:[{text:{content:String(idea.topic||'без темы').slice(0,1900)}}]},\n  'status':{select:{name:'Needs Review'}},\n  'platform':{select:{name:'youtube'}},\n  'content_format':rt('video/shorts'),\n  'post_text':rt(concept.hook_text||''),\n  'final_text':rt(JSON.stringify(concept)),\n  'cta':rt(concept.cta||''),\n  'start_code':rt(idea.start_code),\n  'target_audience':{select:{name:String(idea.audience_segment||'занятые').split('|')[0].trim()}},\n  'post_hash':rt(idea.topic_hash),\n  'created_at':{date:{start:new Date().toISOString()}},\n  'updated_at':{date:{start:new Date().toISOString()}}\n};\nreturn [{ json: { topic: idea.topic, total: idea.total, start_code: idea.start_code, caption, notion_props: props } }];"
      },
