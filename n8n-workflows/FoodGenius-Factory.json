    {
      "parameters": {
        "jsCode": "const raw=$input.first().json.candidates[0].content.parts[0].text;\nconst idea=JSON.parse(raw.trim().replace(/^```json/i,'').replace(/^```/,'').replace(/```$/,'').trim());\nconst t=+idea.trend_score||0,u=+idea.usefulness_score||0,v=+idea.viral_score||0,pf=+idea.product_fit_score||0;\nidea.total=+(t*0.2+u*0.3+v*0.25+pf*0.25).toFixed(2);\nconst s=(idea.topic||'').toLowerCase().replace(/[^0-9a-zа-яё ]/gi,'').replace(/\\s+/g,' ').trim();\nlet h=5381; for(let i=0;i<s.length;i++){h=(((h<<5)+h)+s.charCodeAt(i))&0xffffffff;}\nidea.topic_hash='h'+(h>>>0).toString(16);\nidea.start_code='YT'+(h>>>0).toString(16).toUpperCase().slice(0,6);\nreturn [{ json: idea }];"
      },
