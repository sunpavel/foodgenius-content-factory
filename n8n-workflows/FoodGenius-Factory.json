    {
      "parameters": {
        "jsCode": "const sc = $('ScrapeCreators').first().json || {};\nconst list = (sc.search_item_list||[]).map(it=>{const a=it.aweme_info||{};return {d:(a.desc||'').trim(),v:(a.statistics||{}).play_count||0};}).filter(x=>x.d).sort((a,b)=>b.v-a.v).slice(0,8);\nconst signals = list.map((r,i)=>`${i+1}. [${r.v.toLocaleString('ru-RU')}] ${r.d}`).join('\\n') || '(нет данных)';\nlet trends='(нет)';\ntry{ trends = $('Perplexity').first().json.choices[0].message.content; }catch(e){}\nreturn [{ json: { signals_text: signals, trends_text: trends } }];"
      },
